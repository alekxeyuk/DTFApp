<Page
    x:Class="DTFApp.EntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DTFApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="&lt; Back" Click="BackButton_Click" Margin="10,10,10,0"/>

        <ScrollViewer x:Name="EntryScrollViewer" Grid.Row="1">
            <StackPanel x:Name="BlocksPanel" Margin="10" />
        </ScrollViewer>
    </Grid>
</Page>