<Page
    x:Class="DTFApp.Views.CommentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:DTFApp.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&lt; Back" Click="BackButton_Click"/>
            <TextBlock
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Comments"/>
        </Grid>

        <Grid Grid.Row="1">
            <ListView
                x:Name="CommentsListView"
                ItemsSource="{x:Bind ViewModel.Comments, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CommentViewItem">
                        <StackPanel Margin="{x:Bind IndentMargin}" Padding="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse
                                    Grid.Column="0"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Top">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind AuthorName}"
                                        TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="0,0,6,0"
                                            FontSize="12"
                                            Text="{x:Bind NicknameText}"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{x:Bind NicknameVisibility}"/>
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="12"
                                            Text="{x:Bind TimeAgo}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{x:Bind Text}"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind TextVisibility}"/>
                            <ItemsControl
                                Margin="0,0,0,0"
                                ItemsSource="{x:Bind MediaAttachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:CommentMediaAttachmentViewItem">
                                        <StackPanel Margin="0,8,0,8">
                                            <Image
                                                MaxHeight="220"
                                                HorizontalAlignment="Left"
                                                Source="{Binding Url}"
                                                Stretch="Uniform"/>
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Title}"
                                                TextWrapping="Wrap"
                                                Visibility="{x:Bind TitleVisibility}"/>
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="Gray"
                                                Text="{x:Bind Hostname}"
                                                TextWrapping="Wrap"
                                                Visibility="{x:Bind HostnameVisibility}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">
                <ProgressRing
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="14"
                    Foreground="Gray"
                    Text="Loading comments..."/>
            </StackPanel>

            <TextBlock
                Margin="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="Gray"
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"/>

            <TextBlock
                Margin="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="Gray"
                Text="No comments"
                Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Page>
